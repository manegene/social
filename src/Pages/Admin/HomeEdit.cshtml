@page
@model Kmums.Pages.Admin.HomeEditModel

@{
    ViewData["Title"] = "HomeEdit";
}

<h1>HomeEdit</h1>

<h4>HomeModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="HomeModel.Id" />
            <div class="form-group">
                <label asp-for="HomeModel.Body" class="control-label"></label>
                <textarea id="smarttext" rows="12" asp-for="HomeModel.Body" class="form-control" ></textarea>
                <span asp-validation-for="HomeModel.Body" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
