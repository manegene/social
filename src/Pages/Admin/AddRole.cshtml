@page
@model Kmums.Pages.Admin.AddRoleModel

@{
    ViewData["Title"] = "AddRole";
}

<h1>Add a new user role</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="AddNew.Name" class="control-label"></label>
                <input asp-for="AddNew.Name" class="form-control" />
                <span asp-validation-for="AddNew.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
