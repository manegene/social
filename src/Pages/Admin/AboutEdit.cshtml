@page
@model Kmums.Pages.Admin.AboutEditModel

@{
    ViewData["Title"] = "AboutEdit";
}

<h1>AboutEdit</h1>

<h4>AboutUsModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AboutUsModel.Id" />
            <div class="form-group">
                <label asp-for="AboutUsModel.Message" class="control-label"></label>
                <textarea id="smarttext" asp-for="AboutUsModel.Message" class="form-control" rows="12"></textarea>
                <span asp-validation-for="AboutUsModel.Message" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
