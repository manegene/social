@using System.Security.Principal
@using Kmums.Models.User
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UserModel> SignIn

<ul class="navbar-nav">
@if (User.Identity?.IsAuthenticated == true)
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/account/manage/index">
                <span class="navbar-text text-dark">@User.Identity?.Name.ToLower()</span>
            </a>
    </li>
        
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">Sign out</button>
            </form>
        </li>
}
else
{
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
        </li>
}
</ul>
