@page
@model ChatModel
@{
    //ViewData["Title"]="My messages";
    Html.SetSeoInfo(seoInfo =>
       {
           seoInfo.SetCommonInfo(
       pageTitle: "my messages",
       description: "KilimanimumsKe, open graph (og:), and ...",
       url: "https://kilimanimums.ke/chats",
       keywordTags: new[] { "kilimanimumsKe", "Kilimanimums", "premium dating", "kenya dating site" } //optional
           );

           seoInfo.SetImageInfo(
       url: "https://kilimanimums.ke/images/logo.png",
       width: 1280,  //optional
       height: 720,  //optional
       alt: "KilimanimumsKe"  //optional
                              //mimeType: "image/jpeg", //optional (detects from url file extension if not set.)
           );
       });
}

<table class="table">
        <thead class="thead-dark">
            <tr>
            <th >subject</th>
            <th >received date</th>

            <th >message</th>

            </tr>
</thead>
<tbody>
    @if(Model.SavedChats.Count()>0)
    {
    foreach (var item in Model.SavedChats)
        {
    <tr>
            <td>
                        @Html.DisplayFor(modelItem=>item.Title)
            </td>
            <td>
                        @Html.Raw(item.Sent)
            </td>
            <td>
                        @Html.Raw(item.Body)
            </td>
            <td>
            <a data-bs-toggle="modal" href="#ReplyModal" data-id="@item.Id" data-title=@item.Title class="reply btn btn-info">reply</a>
            </td>

            

    </tr>
        }
    }
    else
    {
        <tr>
            <td>
            @if (ViewData.ModelState["RespMsg"].Errors.Any()){
                
                <h3 align="center" style="color:yellowgreen">@Html.ValidationMessage("RespMsg")</h3>
            }
            else{
                <p>
                    You have no messages yet
                </p>
            }
            </td>

            </tr>
        
                    
          
    }
    </tbody>

                    
</table>

<div class="modal fade" id="ReplyModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="replymodaltitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <form id="reply-form" method="post" class="reply-form" asp-page-handler="Reply">

                        <input type="hidden" asp-for="MsgId" id="msgid" />
                        <div class="form-floating">
                            <label asp-for="RespMsg" class="form-label"></label>
                            <textarea id="usertext" rows="9" cols="8" id="msgbody" maxlength="250" asp-for="RespMsg" class="form-control"></textarea>
                            <span asp-validation-for="RespMsg" class="text-danger"></span>
                        </div>

                        <div class="modal-footer">
                            <button type="button" data-bs-dismiss="modal" class="btn btn-secondary">dismiss</button>
                            <button type="submit" class="btn btn-primary">Send</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

