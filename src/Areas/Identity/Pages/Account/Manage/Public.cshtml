@page
@model Kmums.Areas.Identity.Pages.Account.Manage.PublicModel
@{
    //ViewData["Title"] = "my public profile";
    Html.SetSeoInfo(seoInfo =>
       {
           seoInfo.SetCommonInfo(
           pageTitle: "my public profile",
           description: "KilimanimumsKe, open graph (og:), and ...",
           url: "https://kilimanimums.ke/photos/",
           keywordTags: new[] { "kilimanimumsKe", "Kilimanimums", "premium dating", "kenya dating site" } //optional
       );

           seoInfo.SetImageInfo(
           url: "https://kilimanimums.ke/images/logo.png",
           width: 1280,  //optional
           height: 720,  //optional
           alt: "KilimanimumsKe"  //optional
                                  //mimeType: "image/jpeg", //optional (detects from url file extension if not set.)
       );
    });
}

<h4>@ViewData["Title"]</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @if (Model.UserPublicModel !=null)
            {
                <input type="hidden" asp-for="UserPublicModel.Id" />
            }
            <div class="form-group">
                <label asp-for="UserPublicModel.Heading" class="control-label"></label>
                <input rows="4" maxlength="20" cols="5" asp-for="UserPublicModel.Heading" class="form-control" required=true />
                <span asp-validation-for="UserPublicModel.Heading" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserPublicModel.About" class="control-label"></label>
                <textarea id="usertext" rows="7" maxlength="200" cols="9"col asp-for="UserPublicModel.About" class="form-control" required=true ></textarea>
                <span asp-validation-for="UserPublicModel.About" class="text-danger"></span>
            </div>
            <div class="form-group">
                <select asp-for="UserPublicModel.CategoryId"
                        class="form-control" asp-items="@(new SelectList(Model.Categories,"Id","Name")) ">
                    <option value="0">Select a category</option>
                </select>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }